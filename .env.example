# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Maps
GOOGLE_MAPS_API_KEY=your-server-maps-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-client-maps-key

# Google Drive (service account)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_DRIVE_FOLDER_INVOICES=your-folder-id
GOOGLE_DRIVE_FOLDER_DRIVER_DOCS=your-folder-id

# Brevo (transactional emails)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@capeload.co.za
BREVO_SENDER_NAME=CapeLoad Logistics
